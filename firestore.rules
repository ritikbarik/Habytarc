rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isOwnerTrackingId(trackingId) {
      return isSignedIn()
        && (
          trackingId.matches('^v2_' + request.auth.uid + '_.*$')
          || trackingId.matches('^' + request.auth.uid + '_.*$')
        );
    }

    match /users/{uid} {
      allow read, create, update, delete: if isOwner(uid);

      match /todos/{todoId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /ai_chat/{messageId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /feedback/{feedbackId} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }

    match /habits/{habitId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow read, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
    }

    match /tracking/{trackingId} {
      allow create: if isSignedIn()
        && (
          request.resource.data.userId == request.auth.uid
          || isOwnerTrackingId(trackingId)
        );

      allow read, delete: if isSignedIn()
        && (
          // Current docs
          resource.data.userId == request.auth.uid
          // Backward compatibility: allow owner migration for legacy docs
          || !('userId' in resource.data)
          // Also allow access by owner-encoded tracking doc ID
          || isOwnerTrackingId(trackingId)
        );

      allow update: if isSignedIn()
        && (
          // Current docs
          (
            resource.data.userId == request.auth.uid
            && request.resource.data.userId == resource.data.userId
          )
          // Legacy docs without userId: allow stamping userId on first update
          || (
            !('userId' in resource.data)
            && request.resource.data.userId == request.auth.uid
          )
          // Fallback for legacy/malformed docs keyed by owner UID
          || isOwnerTrackingId(trackingId)
        );
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

AI_PROVIDER=gemini

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACKS=gemini-2.5-flash,gemini-2.0-flash

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct

AI_API_PORT=8787

# Firebase Cloud Messaging (Web Push)
# Generate Web Push certificate (VAPID) in Firebase Console and set public key for frontend.
VITE_FIREBASE_VAPID_KEY=

# Backend push scheduler auth and Firebase Admin SDK credentials.
PUSH_CRON_SECRET=change_me_to_random_secret
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Frontend (Vite): set this in production so /chat can reach your deployed API server.
# Example: https://habytarc-api.onrender.com
VITE_AI_API_BASE_URL=
